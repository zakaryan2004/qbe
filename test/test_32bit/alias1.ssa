export function w $main() {
@start
	%a =w alloc4 4
	%b =w alloc4 4
	storew 4, %a
	storew 5, %b

@loop
	# %mem will be %a and %b successively,
	# but we do not know it when processing
	# the phi because %b goes through a cpy
	%mem =w phi @start %a, @loop %bcpy

	%w =w load %mem
	%eq5 =w ceqw %w, 5
	%bcpy =w copy %b
	jnz %eq5, @exit, @loop

@exit
	ret 0
}
