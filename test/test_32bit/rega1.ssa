# tests that %b and %a0 do not end up in
# the same register at the start of @loop

export function w $f(w %a) {
@start
@loop
	%b =w phi @start 42, @loop0 %a1, @loop1 %a1
	%a0 =w phi @start %a, @loop0 %a1, @loop1 %a1
	%a1 =w sub %a0, 1
	jnz %b, @loop0, @loop1
@loop0
	jnz %a1, @loop, @end
@loop1
	jnz %a1, @loop, @end
@end
	ret %b
}

