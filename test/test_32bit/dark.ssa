# skip arm64 arm64_apple rv64 amd64_win
# a hack example,
# we use a dark type to get
# a pointer to the stack.

type :magic = align 1 { 0 }

data $ret = { w 0 }

export
function $test(:magic %p) {
@start
	%av =w loadw $a
	%a1 =w add 1, %av
	storew %a1, $a       # increment $a
	%r1 =w loadw $ret    # fetch from $ret
	%p1 =w sub %p, 4
	%r2 =w loadw %p1     # get the return address
	storew %r2, $ret     # store it in $ret
	%c =w ceqw %r1, %r2
	jnz %c, @fin, @cal
@cal
	%i =w call $test()   # no argument given, intentionally!
@fin
	ret
}

