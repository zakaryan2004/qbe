# amd64 address-folding stress

export function w $f0(w %a, w %b) {
@start
	%c =w add %b, 2
	%d =w mul %c, 4
	%e =w add %a, %d
	%q =w loadw %e
	ret %q
}

export function w $f1(w %a, w %b) {
@start
	%c =w add 1, %b
	%f =w add %c, 1
	%d =w mul %f, 4
	%e =w add %d, %a
	%q =w loadw %e
	ret %q
}

export function w $f2(w %a, w %b) {
@start
	%l =w mul %b, 4
	%d =w add 8, %l
	%e =w add %a, %d
	%q =w loadw %e
	ret %q
}

# fixme: folding is not good here
export function w $f3(w %a, w %b) {
@start
	%l =w mul %b, 4
	%d =w add 4, %l
	%f =w add 4, %d
	%e =w add %a, %f
	%q =w loadw %e
	ret %q
}

export function w $f4(w %a, w %b) {
@start
	%c =w add 1, %b
	%d =w mul %c, 4
	%e =w add 4, %d
	%f =w add %e, %a
	%q =w loadw %f
	ret %q
}

