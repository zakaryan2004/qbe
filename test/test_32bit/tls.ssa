# skip amd64_win (pthread and tls not implemented)
thread data $i = align 4 {w 42}
data $fmti = align 1 {b "i%d==%d\n", b 0}

thread data $x = {w 1, w 2, w 3, w 4}
data $fmtx = align 1 {b "*(x+%d)==%d\n", b 0}

export
function w $main() {
@start
	%pthr =w alloc8 8
	%rval =w alloc8 8
	call $pthread_create(w %pthr, w 0, w $thread, w 0)
	%t =w load %pthr
	call $pthread_join(w %t, w %rval)
	%i0 =w loadw thread $i
	call $printf(w $fmti, ..., w 0, w %i0)
	%i1 =w load %rval
	call $printf(w $fmti, ..., w 1, w %i1)

	%a0 =w call $xaddr()
	%x0 =w load %a0
	call $printf(w $fmtx, ..., w 0, w %x0)
	%a4 =w call $xaddroff4()
	%x4 =w load %a4
	call $printf(w $fmtx, ..., w 4, w %x4)
	%a8 =w call $xaddroff(w 8)
	%x8 =w load %a8
	call $printf(w $fmtx, ..., w 8, w %x8)
	%xc =w call $xvalcnt(w 3)
	call $printf(w $fmtx, ..., w 12, w %xc)
	ret 0
}

function w $thread(w %arg) {
@start
	%i3 =w add thread $i, 3
	storeb 24, %i3
	%ret =w loadsw thread $i
	ret %ret
}

function w $xaddr() {
@start
	ret thread $x
}

function w $xaddroff4() {
@start
	%a =w add 4, thread $x
	ret %a
}

function w $xaddroff(w %off) {
@start
	%a =w add thread $x, %off
	ret %a
}

function w $xvalcnt(w %cnt) {
@start
	%o =w mul 4, %cnt
	%a =w add thread $x, %o
	%x =w load %a
	ret %x
}

# >>> output
