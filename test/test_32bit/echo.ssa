export
function w $main(w %argc, w %argv) {
@start
	%fmt =w alloc4 8
	storew 1663398693, %fmt             # "%s%c"
	%fmt4 =w add %fmt, 4
	storeb 0, %fmt4                     # null terminator
	%av0 =w add %argv, 4
	%ac0 =w sub %argc, 1
@loop
	%av =w phi @start %av0, @loop2 %av1
	%ac =w phi @start %ac0, @loop2 %ac1
	%c0 =w ceqw %ac, 0
	jnz %c0, @end, @loop1
@loop1
	%c1 =w ceqw %ac, 1
	jnz %c1, @last, @nolast
@last
	jmp @loop2
@nolast
	jmp @loop2
@loop2
	%sep =w phi @last 10, @nolast 32
	%arg =w loadw %av
	%r =w call $printf(w %fmt, ..., w %arg, w %sep)
	%av1 =w add %av, 4
	%ac1 =w sub %ac, 1
	jmp @loop
@end
	ret 0
}

