export function $test_va(w %fixed, ...) {
@start
    %vp =w alloc4 8
    vastart %vp

    # Extract a single-precision float ('s'). 
    # If this only advances the pointer by 4 bytes instead of 8...
    %fval =d vaarg %vp
    
    # ...then this integer extraction will read the upper 4 bytes 
    # of the integer we just passed, resulting in a garbage integer.
    %ival =w vaarg %vp
    
    %r =w call $printf(w $fmt, ..., d %fval, w %ival)
    ret
}

data $fmt = { b "Float: %f, Int: %d\n", b 0 }

# >>> driver
# #include <stdio.h>
# extern void test_va(int fixed, ...);
# int main() {
#     // The 3.14f will be promoted to an 8-byte double on the stack.
#     // The 42 is a 4-byte integer directly after it.
#     test_va(1, 3.14f, 42);
#     return 0;
# }
# <<<

# >>> output
# Float: 3.140000, Int: 42
# <<<