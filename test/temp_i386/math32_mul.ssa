# Test 32-bit multiplication variants on i386.

export function w $test_mul(w %a, w %b) {
@start
    %r =w mul %a, %b
    ret %r
}

export function w $test_neg(w %a) {
@start
    %r =w neg %a
    ret %r
}

export function w $test_udiv(w %a, w %b) {
@start
    %r =w udiv %a, %b
    ret %r
}

export function w $test_urem(w %a, w %b) {
@start
    %r =w urem %a, %b
    ret %r
}

