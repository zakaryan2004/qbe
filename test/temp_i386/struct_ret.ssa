type :st = { w, w, w }

function :st $make_st(w %a, w %b, w %c) {
@start
    %p =w alloc4 12
    storew %a, %p
    %p4 =w add %p, 4
    storew %b, %p4
    %p8 =w add %p, 8
    storew %c, %p8
    ret %p
}

export function w $test() {
@start
    # The caller automatically allocates space for the return struct
    # and QBE assigns the hidden pointer to %v.
    %v =:st call $make_st(w 10, w 20, w 30)
    
    # Prove the callee successfully wrote to our memory
    %p4 =w add %v, 4
    %b =w loadw %p4
    ret %b
}

# >>> driver
# #include <stdio.h>
# extern int test();
# int main() {
#     printf("Result: %d\n", test());
#     return 0;
# }
