type :four = {w, b, w}

data $z = { w 0 }

export
function $test() {
@start
	%a  =w loadw $z
	%y  =w add %a, %a

	%s  =w alloc4 12   # allocate a :four struct
	%s1 =w add %s, 8  # get address of the w
	storew 4, %s       # set the w
	storew 5, %s1      # set the w

	# only the last argument should be on the stack
	%f  =w add $F, %y
	%x  =w call %f(w %y, w 1, w 2, w 3, :four %s, w 6)

	# store the result in the
	# global variable a

	%x1 =w add %y, %x
	storew %x1, $a
	ret
}

