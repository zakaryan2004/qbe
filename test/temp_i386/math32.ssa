# Test 32-bit arithmetic: div, rem, shifts, logical ops.

export function w $test_sar(w %x, w %n) {
@start
    %r =w sar %x, %n
    ret %r
}

export function w $test_div(w %a, w %b) {
@start
    %r =w div %a, %b
    ret %r
}

export function w $test_rem(w %a, w %b) {
@start
    %r =w rem %a, %b
    ret %r
}

export function w $test_shl(w %a, w %b) {
@start
    %r =w shl %a, %b
    ret %r
}

export function w $test_shr(w %a, w %b) {
@start
    %r =w shr %a, %b
    ret %r
}

export function w $test_and(w %a, w %b) {
@start
    %r =w and %a, %b
    ret %r
}

export function w $test_or(w %a, w %b) {
@start
    %r =w or %a, %b
    ret %r
}

export function w $test_xor(w %a, w %b) {
@start
    %r =w xor %a, %b
    ret %r
}

